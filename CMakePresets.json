{
  "version": 3,
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Ninja",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      },
      "binaryDir": "${sourceDir}/bin/Debug",
      "installDir": "${sourceDir}/out/install/Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Ninja",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      },
      "binaryDir": "${sourceDir}/bin/Release",
      "installDir": "${sourceDir}/out/install/Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "relwithdebinfo",
      "displayName": "RelWithDebInfo",
      "generator": "Ninja",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      },
      "binaryDir": "${sourceDir}/bin/RelWithDebInfo",
      "installDir": "${sourceDir}/out/install/RelWithDebInfo",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "asan",
      "displayName": "ASAN",
      "generator": "Ninja",
      "architecture": {
        "value": "x86",
        "strategy": "external"
      },
      "binaryDir": "${sourceDir}/bin/ASAN",
      "installDir": "${sourceDir}/out/install/ASAN",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "ZENITH_ASAN": "ON"
      }
    },
    {
      "name": "clang-tidy",
      "displayName": "clang-tidy",
      "inherits": "debug",
      "cacheVariables": {
        "ZENITH_CLANG_TIDY": "ON"
      }
    }
  ]
}